#!/usr/bin/env bash
# Generated by vortex-cfd for case: {{ case_name }}
# Runs the full Phase A pipeline manually (useful for re-running without Python).
# Source your OpenFOAM etc/bashrc before executing.
set -e

cd "$(dirname "$0")"

{% if cores > 1 %}
NP={{ cores }}
MPI="mpirun -np $NP"
{% else %}
MPI=""
{% endif %}

echo "[Allrun] surfaceFeatureExtract"
surfaceFeatureExtract

echo "[Allrun] blockMesh"
blockMesh

{% if cores > 1 %}
echo "[Allrun] decomposePar (snappyHexMesh)"
decomposePar

echo "[Allrun] snappyHexMesh -parallel"
$MPI snappyHexMesh -overwrite -parallel

echo "[Allrun] reconstructParMesh"
reconstructParMesh -constant

{% else %}
echo "[Allrun] snappyHexMesh"
snappyHexMesh -overwrite

{% endif %}
echo "[Allrun] checkMesh"
checkMesh

{% if cores > 1 %}
echo "[Allrun] decomposePar (pimpleFoam)"
decomposePar -force

echo "[Allrun] pimpleFoam -parallel"
$MPI pimpleFoam -parallel

echo "[Allrun] reconstructPar"
reconstructPar

{% else %}
echo "[Allrun] pimpleFoam"
pimpleFoam

{% endif %}
echo "[Allrun] Done — open {{ case_name }}.foam in ParaView."
