FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}

castellatedMesh true;
snap            true;
addLayers       true;

// ── Geometry ─────────────────────────────────────────────────────────────────
geometry
{
{% for stl_name in all_stls %}
    {{ stl_name }}.stl
    {
        type    triSurfaceMesh;
        name    {{ stl_name }};
    }

{% endfor %}
}

// ── Castellated mesh ─────────────────────────────────────────────────────────
castellatedMeshControls
{
    maxLocalCells           1000000;
    maxGlobalCells          5000000;
    minRefinementCells      10;
    maxLoadUnbalance        0.10;
    nCellsBetweenLevels     3;

    // Feature-edge snapping: one entry per surface extracted by surfaceFeatureExtract
    features
    (
{% for stl_name in all_stls %}
        { file "{{ stl_name }}.eMesh";  level 1; }
{% endfor %}
    );

    refinementSurfaces
    {
        {{ wall_patch }}
        {
            // 4 levels → ~0.125 mm cells at the wall from a 2 mm background
            level       (3 4);
            patchInfo   { type wall; inGroups (wall); }
        }

        {{ inlet_patch }}
        {
            level       (2 3);
            patchInfo   { type patch; }
        }

{% for outlet in outlet_patches %}
        {{ outlet }}
        {
            level       (2 3);
            patchInfo   { type patch; }
        }

{% endfor %}
    }

    resolveFeatureAngle 30;

    refinementRegions {}

    // Must be inside the fluid domain (vessel lumen).
    // Computed as the centre of the wall-STL bounding box.
    locationInMesh  ( {{ "%.6f"|format(location_in_mesh[0]) }}
                      {{ "%.6f"|format(location_in_mesh[1]) }}
                      {{ "%.6f"|format(location_in_mesh[2]) }} );

    allowFreeStandingZoneFaces  true;
}

// ── Snap ─────────────────────────────────────────────────────────────────────
snapControls
{
    nSmoothPatch            3;
    tolerance               4.0;
    nSolveIter              30;
    nRelaxIter              5;
    nFeatureSnapIter        10;
    implicitFeatureSnap     false;
    explicitFeatureSnap     true;
    multiRegionFeatureSnap  false;
}

// ── Boundary layers ───────────────────────────────────────────────────────────
// 4 prismatic layers on the wall only (not on inlet/outlet caps).
// relativeSizes = yes: thicknesses are fractions of local bulk-cell size,
// which is robust when mesh density varies along the vessel.
// finalLayerThickness 0.3 → outermost layer ≈ 0.3 × local cell size.
// With 4 layers at expansion 1.3 the first-cell y+ ≈ 1 for laminar Re 400.
addLayersControls
{
    relativeSizes               yes;

    layers
    {
        {{ wall_patch }}
        {
            nSurfaceLayers  4;
        }
    }

    expansionRatio              1.3;
    finalLayerThickness         0.3;
    minThickness                0.1;
    nGrow                       0;

    featureAngle                60;
    slipFeatureAngle            30;
    nRelaxIter                  3;
    nSmoothSurfaceNormals       1;
    nSmoothNormals              3;
    nSmoothThickness            10;
    maxFaceThicknessRatio       0.5;
    maxThicknessToMedialRatio   0.3;
    minMedialAxisAngle          90;
    nBufferCellsNoExtrude       0;
    nLayerIter                  50;
}

// ── Mesh quality ──────────────────────────────────────────────────────────────
meshQualityControls
{
    #include "meshQualityDict"

    nSmoothScale    4;
    errorReduction  0.75;
}

writeFlags
(
    scalarLevels
    layerSets
    layerFields
);

mergeTolerance  1e-6;
