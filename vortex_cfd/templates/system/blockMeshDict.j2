FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}

// Background box - geometry already in metres (scaling applied upstream).
// 20 % buffer added on all sides so snappyHexMesh cells outside the geometry
// are genuinely outside the bounding box.
scale   1;

vertices
(
    ( {{ "%.6f"|format(bbox.xmin) }}  {{ "%.6f"|format(bbox.ymin) }}  {{ "%.6f"|format(bbox.zmin) }} )  // 0
    ( {{ "%.6f"|format(bbox.xmax) }}  {{ "%.6f"|format(bbox.ymin) }}  {{ "%.6f"|format(bbox.zmin) }} )  // 1
    ( {{ "%.6f"|format(bbox.xmax) }}  {{ "%.6f"|format(bbox.ymax) }}  {{ "%.6f"|format(bbox.zmin) }} )  // 2
    ( {{ "%.6f"|format(bbox.xmin) }}  {{ "%.6f"|format(bbox.ymax) }}  {{ "%.6f"|format(bbox.zmin) }} )  // 3
    ( {{ "%.6f"|format(bbox.xmin) }}  {{ "%.6f"|format(bbox.ymin) }}  {{ "%.6f"|format(bbox.zmax) }} )  // 4
    ( {{ "%.6f"|format(bbox.xmax) }}  {{ "%.6f"|format(bbox.ymin) }}  {{ "%.6f"|format(bbox.zmax) }} )  // 5
    ( {{ "%.6f"|format(bbox.xmax) }}  {{ "%.6f"|format(bbox.ymax) }}  {{ "%.6f"|format(bbox.zmax) }} )  // 6
    ( {{ "%.6f"|format(bbox.xmin) }}  {{ "%.6f"|format(bbox.ymax) }}  {{ "%.6f"|format(bbox.zmax) }} )  // 7
);

blocks
(
    hex (0 1 2 3 4 5 6 7)  ( {{ nx }}  {{ ny }}  {{ nz }} )  simpleGrading (1 1 1)
);

edges ();

boundary
(
    background
    {
        type patch;
        faces
        (
            (0 3 2 1)   // -z
            (4 5 6 7)   // +z
            (0 1 5 4)   // -y
            (2 3 7 6)   // +y
            (0 4 7 3)   // -x
            (1 2 6 5)   // +x
        );
    }
);
